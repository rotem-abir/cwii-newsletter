# Copy to .env and fill in (never commit .env).
# Or use `npx wrangler login` and omit CLOUDFLARE_API_TOKEN for interactive auth.

# Optional: non-interactive / CI. Not required if you ran `wrangler login`.
# CLOUDFLARE_API_TOKEN=

# Required for npm run r2:smoke-upload
# R2_BUCKET_NAME=your-bucket-name

# Object key prefix for newsletter HTML (trailing slash recommended)
# R2_NEWSLETTER_PREFIX=newsletter/

# Doc only: public base URL for sanity checks after upload (not read by scripts)
# R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
